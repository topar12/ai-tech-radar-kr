# Legacy local FastAPI reference only.
# Production runs on Cloudflare Worker/D1 and does not read this file.
APP_NAME=Lokana API
ADMIN_TOKEN=replace-with-a-long-random-token
DATABASE_URL=sqlite:///backend/data/lokana.sqlite3
CORS_ORIGINS=http://127.0.0.1:8765,http://localhost:8765
COLLECTOR_TIMEOUT_SECONDS=15
COLLECTOR_MAX_ITEMS_PER_FEED=4
SSL_CERT_FILE=/etc/ssl/cert.pem
# Optional for later collectors:
GITHUB_TOKEN=
HF_TOKEN=
